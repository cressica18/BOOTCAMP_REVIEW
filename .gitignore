# Node modules
node_modules/
**/node_modules/

# Env files
.env
.env.*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
**/dist/
**/build/

# Coverage
coverage/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Temp files
*.tmp
*.temp
*.bak
*.swp
*~

# Docker
docker-compose.override.yml
**/.DS_Store

# Vite cache
node_modules/.vite
.vite

# Test and reporting
*.lcov

# Misc
!.dockerignore
!Dockerfile
!.env.example
!README.md
!implementation.md

# Do NOT ignore these repo files
!package.json
!package-lock.json

# Ensure backend data file is tracked (do NOT ignore reviews.json)
!backend/data/reviews.json

# Ignore typical backend/frontend artifacts
/frontend/dist/
/frontend/node_modules/
/backend/node_modules/

# Ignore local npm folders
.npm/

# Ignore coverage and logs at repo root
coverage/
logs/
*.log

# Ignore system-specific Docker temporary sockets
docker.sock

# Ignore lockfiles other than package-lock
yarn.lock
pnpm-lock.yaml

# Ignore compiled assets
*.map

# End of .gitignore
